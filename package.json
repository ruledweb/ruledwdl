{
  "name": "@wdl/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "WDL renderer — the language runtime, host-agnostic. Renders WDL JSON (REGISTRY/COMPONENTS/DATA) to HTML given a pluggable store. CMS-flavored features live in optional wdl-extensions/*.",
  "exports": {
    ".": "./src/index.js",
    "./file-store": "./src/stores/file-store.js",
    "./extensions/compose": "./wdl-extensions/compose.js",
    "./extensions/forms": "./wdl-extensions/forms/index.js",
    "./extensions/email": "./wdl-extensions/email/index.js",
    "./extensions/queries": "./wdl-extensions/queries/index.js",
    "./extensions/plugins": "./wdl-extensions/plugins/index.js",
    "./extensions/system-components": "./wdl-extensions/system-components/index.js",
    "./extensions/content-schema": "./wdl-extensions/content-schema/index.js"
  },
  "bin": {
    "wdl": "./bin/wdl.js"
  },
  "scripts": {
    "test": "node test/smoke.test.js && node test/extensions.test.js"
  },
  "dependencies": {
    "marked": "^12.0.2"
  },
  "license": "UNLICENSED"
}
