{
  "name": "@ruledwdl/core",
  "version": "0.1.1",
  "description": "Web Definition Language (WDL) core runtime and component layout engine.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/ruledwdl.js",
  "module": "./dist/ruledwdl.esm.js",
  "unpkg": "./dist/ruledwdl.min.js",
  "jsdelivr": "./dist/ruledwdl.min.js",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./src/index.js",
      "default": "./dist/ruledwdl.js"
    },
    "./file-store": "./src/stores/file-store.js"
  },
  "bin": {
    "ruledwdl": "./bin/ruledwdl.js"
  },
  "files": [
    "src",
    "bin",
    "dist/ruledwdl*.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild src/index.js --bundle --format=iife --global-name=WDL --outfile=dist/ruledwdl.js && esbuild src/index.js --bundle --format=iife --global-name=WDL --minify --outfile=dist/ruledwdl.min.js && esbuild src/index.js --bundle --format=esm --outfile=dist/ruledwdl.esm.js",
    "test": "node test/smoke.test.js"
  },
  "keywords": [
    "wdl",
    "web-definition-language",
    "ruledwdl",
    "renderer",
    "layers",
    "html",
    "template-engine"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RuledSEO/ruledwdl.git"
  },
  "dependencies": {
    "marked": "^12.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
